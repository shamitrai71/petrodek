# ============================================================
# Petrodek — Environment Variables
# Set ALL of these in Netlify → Site → Environment Variables
# ============================================================

# Neon PostgreSQL connection string
# Neon dashboard → your project → Connection Details → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# JWT signing secret — must be 32+ random characters
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars

# DB auto-setup secret — protects the /.netlify/functions/setup endpoint
# Use any long random string (different from JWT_SECRET)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SETUP_SECRET=replace_with_another_long_random_secret

# Optional: override the default admin credentials on first deploy
# If not set, defaults to esraigroup@gmail.com / super123
# IMPORTANT: change these before first deploy on a production site
ADMIN_EMAIL=esraigroup@gmail.com
ADMIN_PASSWORD=super123
